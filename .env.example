# ============================================================
# market.near.ai Agent — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ------------------------------------------------------------
# LLM Provider (REQUIRED)
# ------------------------------------------------------------

# Which LLM backend to use.
# Allowed values: anthropic | openai | ollama
#   anthropic — Anthropic Claude (requires ANTHROPIC_API_KEY)
#   openai    — OpenAI or OpenAI-compatible API (requires LLM_API_KEY or OPENAI_API_KEY)
#   ollama    — Local Ollama OR any OpenAI-compatible third-party endpoint
#               (set LLM_BASE_URL; set LLM_API_KEY if the endpoint requires auth)
LLM_PROVIDER=anthropic

# Model identifier for the chosen provider.
# Examples: claude-sonnet-4-6  |  gpt-4o  |  llama3  |  near-ai/llama-3.1-70b-instruct
LLM_MODEL=claude-sonnet-4-6

# Base URL for OpenAI-compatible providers (required for ollama and third-party endpoints).
# Leave blank when LLM_PROVIDER=anthropic or LLM_PROVIDER=openai (uses api.openai.com).
# LLM_BASE_URL=http://localhost:11434/v1

# ------------------------------------------------------------
# Provider API Keys (CONDITIONAL)
# ------------------------------------------------------------

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Generic API key for any OpenAI-compatible provider.
# Used when LLM_PROVIDER=openai (required) or LLM_PROVIDER=ollama with a third-party endpoint.
# Takes precedence over OPENAI_API_KEY when both are set.
# LLM_API_KEY=

# Standard OpenAI API key (backwards-compatible alias for LLM_API_KEY).
# Required when LLM_PROVIDER=openai and LLM_API_KEY is not set.
# OPENAI_API_KEY=sk-...

# ── Example: NEAR AI Hub ──────────────────────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_MODEL=near-ai/llama-3.1-70b-instruct
# LLM_BASE_URL=https://inference.near.ai/v1
# LLM_API_KEY=<your-near-ai-api-key>

# ── Example: Groq ─────────────────────────────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...

# ── Example: Local Ollama (no key needed) ────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
# LLM_BASE_URL=http://localhost:11434/v1

# ------------------------------------------------------------
# market.near.ai API (REQUIRED)
# ------------------------------------------------------------

# Bearer token used to authenticate against market.near.ai REST API.
MARKET_API_KEY=your-market-api-key-here

# HTTP timeout for market.near.ai API calls in milliseconds.
# Blockchain-backed endpoints (award, accept, withdraw) submit on-chain transactions
# and can take 30–60 s to settle. Setting this too low risks a partial state where
# funds move on-chain but the job/bid status is not updated.
# Default: 90000 (90 s)
# MARKET_API_TIMEOUT_MS=90000

# ------------------------------------------------------------
# Agent Behaviour (OPTIONAL)
# ------------------------------------------------------------

# Role hint for the agent.
# Allowed values: requester | worker | auto  (default: auto)
# USER_ROLE=auto

# How often to refresh the skill/job catalogue from the API (ms).
# Default: 1800000 (30 minutes)
# SKILL_REFRESH_INTERVAL_MS=1800000

# ------------------------------------------------------------
# Docker Compose (OPTIONAL)
# ------------------------------------------------------------

# Unique name for this stack. Namespaces container names, networks, and volumes
# so multiple stacks can run on the same machine without collision.
# Default: the directory name (docker compose built-in behaviour).
# COMPOSE_PROJECT_NAME=requester

# Host port the market-agent API is published on.  Default: 8080
# AGENT_PORT=8080

# Host port the Open WebUI frontend is published on.  Default: 3000
# WEBUI_PORT=3000

# ── Example: two stacks on one machine ───────────────────────────────────────
# Requester stack (.env):
#   COMPOSE_PROJECT_NAME=requester
#   USER_ROLE=requester
#   AGENT_PORT=8080
#   WEBUI_PORT=3000
#
# Worker stack (.env in a separate copy of the repo, or passed via environment):
#   COMPOSE_PROJECT_NAME=worker
#   USER_ROLE=worker
#   AGENT_PORT=8081
#   WEBUI_PORT=3001

# ------------------------------------------------------------
# Server (OPTIONAL)
# ------------------------------------------------------------

# HTTP port the Node.js server listens on inside the container (or locally
# when running outside Docker).  Default: 8080.
# When running in Docker, use AGENT_PORT above to change the exposed host port
# instead of changing this value.
# PORT=8080

# ------------------------------------------------------------
# Debug (OPTIONAL)
# ------------------------------------------------------------

# Enable verbose request/response logging for all outbound API calls.
# Logs full request and response bodies for LLM providers and market.near.ai.
# API keys and Authorization headers are always redacted even when DEBUG=true.
# Default: false
# DEBUG=true
